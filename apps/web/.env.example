# Public backend URL used by the browser.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Browser chunk duration in milliseconds.
NEXT_PUBLIC_CHUNK_DURATION_MS=5000
# Interval for mismatch reconciliation checks.
NEXT_PUBLIC_RECONCILIATION_INTERVAL_MS=10000
# Interval for retrying failed uploads.
NEXT_PUBLIC_RETRY_INTERVAL_MS=4000
