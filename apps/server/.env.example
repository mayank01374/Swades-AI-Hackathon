# PostgreSQL connection string. Replace with Railway PostgreSQL or your own PostgreSQL instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swades_pipeline
DATABASE_POOL_MAX=30
# Frontend domain allowed to call the API.
CORS_ORIGIN=http://localhost:3001
# Used only when S3_* values are omitted. Chunks are stored on local disk here.
LOCAL_STORAGE_DIR=./data/chunks
PORT=3000
# Optional S3-compatible storage. Leave these empty to keep using local disk storage.
S3_BUCKET_NAME=recording-chunks
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
