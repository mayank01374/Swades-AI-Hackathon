DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swades_pipeline
DATABASE_POOL_MAX=30
CORS_ORIGIN=http://localhost:3001
LOCAL_STORAGE_DIR=./data/chunks
PORT=3000
# Optional S3-compatible storage. If omitted, the server falls back to local disk storage.
S3_BUCKET_NAME=recording-chunks
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
